# =====================================================================
# Ahorr-E — variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# `.env*` está ignorado por git, jamás se sube al repo.
# =====================================================================

# --- Supabase ---
# Encontrar en: dashboard de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# (Opcional, server-only) Service Role Key — solo si necesitas operaciones admin
# que bypaseen RLS. NUNCA poner prefijo NEXT_PUBLIC_ aquí.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / PostgreSQL ---
# DATABASE_URL: connection string de Supabase. Pooler recomendado (puerto 6543).
# Encontrar en: dashboard Supabase → Project Settings → Database → Connection string
DATABASE_URL=

# (Opcional) DIRECT_URL: requerido por Prisma para migraciones cuando DATABASE_URL
# usa el pooler. Apunta al puerto 5432 directo. Descomentar y completar si aplica.
# DIRECT_URL=

# --- Google AI / Gemini ---
# API Key desde https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Opcional) Modelo a usar. Por defecto: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
